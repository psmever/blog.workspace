# Copy to: /var/www/jaubi.co.kr/blog/blog.backend/.env

APP_NAME="MyProject Blog API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://blog.api.jaubi.co.kr

APP_LOCALE=ko
APP_FALLBACK_LOCALE=ko
APP_FAKER_LOCALE=ko_KR

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=blog
DB_USERNAME=blog
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=.jaubi.co.kr
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local
MEDIA_DISK=s3
POST_IMAGE_MAX_KB=10240

CORS_ALLOWED_ORIGINS=https://blog.jaubi.co.kr
SANCTUM_STATEFUL_DOMAINS=blog.jaubi.co.kr,blog.api.jaubi.co.kr

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="MyProject Blog"

AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=ap-northeast-2
AWS_BUCKET=CHANGE_ME
AWS_USE_PATH_STYLE_ENDPOINT=false

# When CloudFront is ready, set this to the CDN domain.
# Example: AWS_URL=https://cdn.jaubi.co.kr
# AWS_URL=
