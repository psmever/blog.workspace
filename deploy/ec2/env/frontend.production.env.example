# Copy to: /var/www/jaubi.co.kr/blog/blog.frontend/.env

NODE_ENV=production

NEXT_PUBLIC_SITE_URL=https://blog.jaubi.co.kr
NEXT_PUBLIC_API_URL=https://blog.api.jaubi.co.kr
NEXT_PUBLIC_API_BASE_CLIENT_HEADER_CODE=CT04P
NEXT_PUBLIC_APP_NAME=My Blog
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_DEBUG_MODE=false

# Optional when you want to override the API base variable name explicitly.
# NEXT_PUBLIC_API_BASE_URL=https://blog.api.jaubi.co.kr
